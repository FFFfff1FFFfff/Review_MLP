generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel Postgres (Neon) injects these; use pooled at runtime, direct for migrations.
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Business {
  id              String          @id @default(cuid())
  name            String
  ownerEmail      String          @unique
  ownerFirstName  String
  // Either googleReviewUrl (override) or googlePlaceId must be set before sending.
  googlePlaceId   String?
  googleReviewUrl String?
  // Localized "Hair salon" / "Coffee shop" string from the Places API result,
  // saved alongside googlePlaceId. Fed into the AI review prompt so drafts use
  // type-appropriate vocabulary instead of generic "great service" filler.
  googleBusinessType String?
  // Google's editorial one-liner about the business (when Places has it),
  // also fed into the AI review prompt for grounding.
  googleEditorialSummary String?
  // Owner-written 1-2 sentence description, fed into the AI prompt as the most
  // authoritative grounding (the owner knows their own business better than
  // Google's auto-classification). Plain text, max ~500 chars enforced at API.
  ownerDescription String?
  // Optional per-business SMS body override.
  smsTemplate     String?
  // Last successful magic-link dispatch — gates the per-email cooldown so
  // /api/auth/request can't be used to email-bomb a registered owner.
  lastMagicLinkSentAt DateTime?
  createdAt       DateTime        @default(now())

  reviewRequests  ReviewRequest[]
}

model ReviewRequest {
  id              String    @id @default(cuid())
  businessId      String
  // Delivery channel chosen at create time: 'sms' or 'email'.
  // Default is 'sms' for legacy rows created before the channel column existed;
  // new rows always set this explicitly in the review-request API.
  deliveryChannel String    @default("sms")
  // Populated when deliveryChannel='sms'. E.164 format, e.g. +15125551234.
  clientPhoneE164 String?
  // SHA-256 of clientPhoneE164 for dedup lookup without exposing PII in queries/logs.
  clientPhoneHash String?
  // Populated when deliveryChannel='email'. Lowercased, trimmed.
  clientEmail     String?
  // SHA-256 of clientEmail for dedup lookup symmetry with phone.
  clientEmailHash String?
  scheduledSendAt DateTime
  sentAt          DateTime?
  clickedAt       DateTime?
  ratedAt         DateTime?
  rating          Int?
  // Client-entered text: their optional note in the rating step. Also feeds
  // the AI generator below as a hint for the suggested Google review.
  reviewText      String?
  // AI-generated draft Google review shown in the 4-5★ paste view. Cached so
  // refreshes don't burn another Claude call. Null until first generation.
  aiSuggestedReview String?
  // 'google' | 'private' — set at rating time based on star count.
  routedTo        String?
  googleClickedAt DateTime?
  // Set when the owner has been emailed about a private-feedback submission.
  feedbackSubmittedAt DateTime?
  optedOut        Boolean   @default(false)
  // Twilio SID once real SMS provider is wired in.
  smsSid          String?
  // Set when Twilio's status callback reports the SMS as delivered to the
  // recipient's device. Distinct from sentAt (which only means Twilio
  // accepted the send). Email rows leave this null.
  smsDeliveredAt  DateTime?
  // Short random slug used in /r/:token URL; unique so lookup is cheap.
  token           String    @unique
  createdAt       DateTime  @default(now())

  business        Business  @relation(fields: [businessId], references: [id])

  @@index([clientPhoneHash])
  @@index([clientEmailHash])
  @@index([scheduledSendAt, sentAt])
  @@index([businessId, createdAt])
}
