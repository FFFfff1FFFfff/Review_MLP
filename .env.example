# Postgres (Vercel Postgres / Neon).
# On Vercel, these are auto-injected when you add the Postgres store.
# Locally, copy their values from `vercel env pull` or the Vercel dashboard.
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Base URL used in magic-link emails
APP_URL=http://localhost:3000

# Magic-link + session JWT secret (32+ random bytes, any string)
AUTH_SECRET=

# Resend
RESEND_API_KEY=
# Until a domain is verified in Resend, keep this as onboarding@resend.dev
# (messages can then only be delivered to the Resend account's own email).
RESEND_FROM="Alauda Review <onboarding@resend.dev>"

# Notifier channel used by the send-reviews cron.
# - console    : log to stdout, do not send (safe default, dev only)
# - email-sms  : production mode — SMS via Twilio, email via Resend
#                (the value name is legacy; kept stable so existing Vercel
#                deployments don't need to re-set it)
NOTIFIER_MODE=console

# Twilio — required when NOTIFIER_MODE=email-sms. Get creds from
# console.twilio.com. Phone number format: +1XXXXXXXXXX (E.164). Trial
# accounts can only send to verified numbers until the account is upgraded.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Vercel Cron adds `Authorization: Bearer ${CRON_SECRET}` to every scheduled
# request. Generate with: openssl rand -base64 32
CRON_SECRET=

# Anthropic API key — used to generate per-customer Google review drafts
# (so multiple happy customers don't paste identical text and trip Google's
# templated-review filter). Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Google Places API key — used by /owner/settings to resolve a Place ID
# from a business name (or validate a pasted ID) so owners don't have to
# edit the DB by hand. Enable "Places API (New)" in GCP Console.
GOOGLE_PLACES_API_KEY=

# Per-business send cap per rolling 24h (cron defers sends beyond this).
# Defaults to 3 in production — keep it low to protect SMB customers from
# over-messaging. In dev/preview you'll likely want VELOCITY_CAP=50 or
# similar so your own testing isn't blocked.
VELOCITY_CAP=
