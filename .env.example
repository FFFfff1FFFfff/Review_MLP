# Postgres (Vercel Postgres / Neon).
# On Vercel, these are auto-injected when you add the Postgres store.
# Locally, copy their values from `vercel env pull` or the Vercel dashboard.
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Base URL used in magic-link emails
APP_URL=http://localhost:3000

# Magic-link + session JWT secret (32+ random bytes, any string)
AUTH_SECRET=

# Resend
RESEND_API_KEY=
# Until a domain is verified in Resend, keep this as onboarding@resend.dev
# (messages can then only be delivered to the Resend account's own email).
RESEND_FROM="Review MLP <onboarding@resend.dev>"

# Notifier channel used by the send-reviews cron.
# - console    : log to stdout, do not send (safe default, dev only)
# - email-sms  : send via Resend to carrier email-to-SMS gateway (@tmomail.net)
NOTIFIER_MODE=console

# Vercel Cron adds `Authorization: Bearer ${CRON_SECRET}` to every scheduled
# request. Generate with: openssl rand -base64 32
CRON_SECRET=

# Anthropic API key — used to generate per-customer Google review drafts
# (so multiple happy customers don't paste identical text and trip Google's
# templated-review filter). Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=
